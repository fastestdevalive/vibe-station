{
  "name": "@viberun/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "vrun": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint --config ../../eslint.config.mjs src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "nock": "^13.5.4",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
