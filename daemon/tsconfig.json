{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "rootDir": "src",
    "outDir": "../cli/dist/daemon",
    "noEmit": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "*": ["../cli/node_modules/@types/*", "../node_modules/@types/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/__tests__/**"]
}
