{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "rootDir": "src",
    "outDir": "../cli/dist/daemon",
    "noEmit": false,
    "typeRoots": ["../cli/node_modules/@types"],
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/__tests__/**"]
}
